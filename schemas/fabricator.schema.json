{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "TODO: define after first SCMDB fabricator scrape",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "category": { "type": "string" },
      "faction": { "type": "string" },
      "unlock_requirements": {
        "type": "object",
        "properties": {
          "rank": { "type": "integer" },
          "missions": { "type": "array", "items": { "type": "string" } }
        }
      },
      "materials": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "quantity": { "type": "number" }
          },
          "required": ["name", "quantity"]
        }
      },
      "disassembly": { "type": "object" }
    },
    "required": ["id", "name", "faction"]
  }
}
